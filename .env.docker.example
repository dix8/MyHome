POSTGRES_DB=myhome
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password

DATABASE_URL=postgresql://postgres:change-this-password@db:5432/myhome
NEXTAUTH_URL=https://your-domain.example.com
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-characters

AUTO_BOOTSTRAP_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_PASSWORD=Admin123456!
